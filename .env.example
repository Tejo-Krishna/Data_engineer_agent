# Anthropic — all LLM reasoning calls go through this
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI — embeddings only (text-embedding-3-small)
OPENAI_API_KEY=sk-your-openai-key-here

# PostgreSQL
POSTGRES_URL=postgresql://user:pass@localhost:5432/dataeng
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dataeng
POSTGRES_USER=user
POSTGRES_PASSWORD=pass

# Redis
REDIS_URL=redis://localhost:6379

# DuckDB (in-process analytics, used by MCP tools)
DUCKDB_PATH=./data/local.duckdb

# MCP Server
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000

# Langfuse observability
# Set these after first `docker compose up` by visiting localhost:3000,
# creating an account and project, then copying the API keys here.
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
LANGFUSE_HOST=http://localhost:3000

# Pipeline behaviour
MAX_QUALITY_RETRIES=3
SANDBOX_TIMEOUT_SECONDS=30
SAMPLE_SIZE=2000

# Directories
LOG_DIR=./logs
OUTPUT_DIR=./outputs
DOMAIN_RULES_DIR=./domain_rules

# FX rate for GBP → USD conversion in seed library and generated code
FX_STATIC_RATE=1.27

# HITL timing
HITL_TIMEOUT_SECONDS=600
HITL_POLL_INTERVAL_SECONDS=2
